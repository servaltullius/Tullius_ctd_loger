<Application
    x:Class="SkyrimDiagDumpToolWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    RequestedTheme="Dark">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <controls:XamlControlsResources />
      </ResourceDictionary.MergedDictionaries>

      <!-- Fluent 2 Clean Dark tokens -->
      <Color x:Key="SystemAccentColor">#FF60CDFF</Color>

      <SolidColorBrush x:Key="CardBackgroundBrush"        Color="#CC202020" />
      <SolidColorBrush x:Key="ElevatedBackgroundBrush"     Color="#E52A2A2A" />
      <SolidColorBrush x:Key="CardBorderBrush"             Color="#33FFFFFF" />
      <SolidColorBrush x:Key="AccentBrush"                 Color="#FF60CDFF" />
      <SolidColorBrush x:Key="AccentSoftBrush"             Color="#2260CDFF" />
      <SolidColorBrush x:Key="InputBackgroundBrush"        Color="#CC1A1A1A" />
      <SolidColorBrush x:Key="ItemBackgroundBrush"         Color="#CC2A2A2A" />
      <SolidColorBrush x:Key="ItemBorderBrush"             Color="#22FFFFFF" />
      <SolidColorBrush x:Key="StatusBackgroundBrush"       Color="#CC1A1A1A" />
      <SolidColorBrush x:Key="StatusBorderBrush"           Color="#33FFFFFF" />
      <SolidColorBrush x:Key="BadgeBackgroundBrush"        Color="#3360CDFF" />
      <SolidColorBrush x:Key="BadgeBorderBrush"            Color="#6660CDFF" />
      <SolidColorBrush x:Key="ConflictBrush"               Color="#FFFF6A5E" />

      <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
      </Style>

      <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{ThemeResource AccentBrush}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
        <Setter Property="BorderBrush" Value="{ThemeResource AccentBrush}" />
        <Setter Property="Padding" Value="24,11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
      </Style>

      <Style TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="{ThemeResource InputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ItemBorderBrush}" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>
