<Window
    x:Class="SkyrimDiagDumpToolWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SkyrimDiagDumpToolWinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Tullius CTD Logger">

  <Grid x:Name="RootGrid" Background="Transparent">

    <!-- Navigation shell -->
    <NavigationView
        x:Name="NavView"
        PaneDisplayMode="Left"
        IsPaneOpen="True"
        IsPaneToggleButtonVisible="False"
        OpenPaneLength="228"
        CompactPaneLength="52"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        SelectionChanged="NavView_SelectionChanged"
        Background="Transparent">

      <NavigationView.PaneHeader>
        <StackPanel Margin="12,12,12,6">
          <TextBlock Text="Tullius"
                     FontSize="20" FontWeight="SemiBold"
                     Foreground="{ThemeResource AccentGradientBrush}" />
          <TextBlock Text="CTD Logger"
                     FontSize="11"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
      </NavigationView.PaneHeader>

      <NavigationView.MenuItems>
        <NavigationViewItem x:Name="NavAnalyze" Tag="analyze" Content="Dashboard" IsSelected="True">
          <NavigationViewItem.Icon><SymbolIcon Symbol="OpenFile" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem x:Name="NavTriage" Tag="triage" Content="Triage">
          <NavigationViewItem.Icon><SymbolIcon Symbol="Important" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem x:Name="NavRawData" Tag="rawdata" Content="Raw Data">
          <NavigationViewItem.Icon><SymbolIcon Symbol="Document" /></NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <!-- Scrollable content area -->
      <ScrollViewer
          x:Name="RootScrollViewer"
          HorizontalContentAlignment="Center"
          VerticalScrollBarVisibility="Auto"
          HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="RootContentGrid"
              MaxWidth="1240"
              MinWidth="640"
              Padding="22,18,22,18"
              HorizontalAlignment="Center"
              VerticalAlignment="Top">

          <!-- ════════════════════════════════════════════
               ANALYZE PANEL
               ════════════════════════════════════════════ -->
          <StackPanel x:Name="AnalyzePanel" Spacing="16" Visibility="Visible" HorizontalAlignment="Stretch">

            <!-- Status ribbon -->
            <Border Background="{ThemeResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,9">
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="HeaderSubtitleText"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           TextWrapping="WrapWholeWords"
                           VerticalAlignment="Center">
                  Skyrim SE detected. Ready for dump triage.
                </TextBlock>
                <Border Grid.Column="1" CornerRadius="999" Padding="12,4"
                        BorderBrush="{ThemeResource BadgeBorderBrush}" BorderThickness="1"
                        Background="{ThemeResource BadgeBackgroundBrush}" VerticalAlignment="Center">
                  <TextBlock x:Name="HeaderBadgeText"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{ThemeResource AccentBrush}"
                             Text="STATUS READY" />
                </Border>
              </Grid>
            </Border>

            <!-- Analysis controls -->
            <Border Background="{ThemeResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="22">
              <StackPanel Spacing="12">
                <TextBlock x:Name="AnalyzeSectionTitleText"
                           FontSize="24" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                  Dump Intake
                </TextBlock>

                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="DumpPathBox"
                           PlaceholderText="Select a .dmp file" MinHeight="42"
                           AutomationProperties.Name="Dump file path" />
                  <Button x:Name="BrowseDumpButton" Grid.Column="1"
                          Click="BrowseDump_Click" Content="Browse dump"
                          AutomationProperties.Name="Browse dump file"
                          ToolTipService.ToolTip="Browse dump file (Ctrl+O)">
                    <Button.KeyboardAccelerators>
                      <KeyboardAccelerator Modifiers="Control" Key="O" />
                    </Button.KeyboardAccelerators>
                  </Button>
                </Grid>

                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="OutputDirBox"
                           PlaceholderText="Optional output directory (empty = dump folder)" MinHeight="42"
                           AutomationProperties.Name="Output directory path" />
                  <Button x:Name="BrowseOutputButton" Grid.Column="1"
                          Click="BrowseOutputFolder_Click" Content="Browse folder"
                          AutomationProperties.Name="Browse output folder" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button x:Name="AnalyzeButton" Click="AnalyzeButton_Click"
                          Content="ANALYZE NOW"
                          Style="{StaticResource PrimaryActionButtonStyle}"
                          AutomationProperties.Name="Analyze dump file"
                          ToolTipService.ToolTip="Analyze dump (F5)">
                    <Button.KeyboardAccelerators>
                      <KeyboardAccelerator Key="F5" />
                    </Button.KeyboardAccelerators>
                  </Button>
                  <Button x:Name="CancelAnalyzeButton" Click="CancelAnalyzeButton_Click"
                          Content="Cancel analysis"
                          IsEnabled="False"
                          AutomationProperties.Name="Cancel analysis" />
                  <Button x:Name="OpenOutputButton" Click="OpenOutputButton_Click"
                          Content="Open report folder"
                          AutomationProperties.Name="Open report folder" />
                </StackPanel>

                <!-- Status -->
                <Border CornerRadius="6"
                        BorderBrush="{ThemeResource StatusBorderBrush}" BorderThickness="1"
                        Background="{ThemeResource StatusBackgroundBrush}" Padding="12,8">
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing x:Name="BusyRing" Width="18" Height="18" IsActive="False" />
                    <TextBlock x:Name="StatusText" FontSize="14"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Text="Ready." TextWrapping="WrapWholeWords" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- ════════════════════════════════════════════
               TRIAGE PANEL  (Single-Page: Summary + Evidence + Events)
               ════════════════════════════════════════════ -->
          <StackPanel x:Name="TriagePanel" Spacing="16" Visibility="Collapsed" HorizontalAlignment="Stretch">

            <!-- Header: title + action buttons -->
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="SnapshotSectionTitleText"
                         Grid.Column="0"
                         FontSize="30" FontWeight="SemiBold"
                         Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                Crash Summary
              </TextBlock>
              <Button x:Name="CopySummaryButton"
                      Grid.Column="1"
                      Click="CopySummaryButton_Click"
                      VerticalAlignment="Center"
                      Padding="14,8"
                      FontSize="13"
                      Content="Copy summary"
                      AutomationProperties.Name="Copy summary to clipboard"
                      ToolTipService.ToolTip="Copy summary (Ctrl+Shift+C)">
                <Button.KeyboardAccelerators>
                  <KeyboardAccelerator Modifiers="Control,Shift" Key="C" />
                </Button.KeyboardAccelerators>
              </Button>
              <Button x:Name="CopyShareButton"
                      Grid.Column="2"
                      Click="CopyShareButton_Click"
                      VerticalAlignment="Center"
                      Padding="14,8"
                      FontSize="13"
                      Content="Share"
                      AutomationProperties.Name="Copy share text to clipboard" />
            </Grid>

            <!-- Summary sentence (full-width) -->
            <Border Background="{ThemeResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource GlowBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
              <StackPanel Spacing="4">
                <TextBlock x:Name="SummarySentenceText"
                           TextWrapping="WrapWholeWords" FontSize="18"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="CorrelationBadge" FontSize="13" Foreground="OrangeRed"
                           Visibility="Collapsed" />
              </StackPanel>
            </Border>

            <!-- KPI 4-card row -->
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0"
                      Background="{ThemeResource ElevatedAcrylicBrush}"
                      BorderBrush="{ThemeResource GlowBorderBrush}"
                      BorderThickness="1" CornerRadius="8" Padding="0">
                <StackPanel>
                  <Border Height="2" CornerRadius="8,8,0,0"
                          Background="{ThemeResource AccentGradientHorizontalBrush}" />
                  <StackPanel Spacing="4" Padding="14">
                    <TextBlock x:Name="QuickPrimaryLabelText"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                      Actionable candidate
                    </TextBlock>
                    <TextBlock x:Name="QuickPrimaryValueText"
                               FontSize="18" FontWeight="SemiBold"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                      -
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border Grid.Column="1"
                      Background="{ThemeResource ElevatedAcrylicBrush}"
                      BorderBrush="{ThemeResource GlowBorderBrush}"
                      BorderThickness="1" CornerRadius="8" Padding="0">
                <StackPanel>
                  <Border Height="2" CornerRadius="8,8,0,0"
                          Background="{ThemeResource AccentGradientHorizontalBrush}" />
                  <StackPanel Spacing="4" Padding="14">
                    <TextBlock x:Name="QuickConfidenceLabelText"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                      Evidence agreement
                    </TextBlock>
                    <TextBlock x:Name="QuickConfidenceValueText"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}">
                      -
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border Grid.Column="2"
                      Background="{ThemeResource ElevatedAcrylicBrush}"
                      BorderBrush="{ThemeResource GlowBorderBrush}"
                      BorderThickness="1" CornerRadius="8" Padding="0">
                <StackPanel>
                  <Border Height="2" CornerRadius="8,8,0,0"
                          Background="{ThemeResource AccentGradientHorizontalBrush}" />
                  <StackPanel Spacing="4" Padding="14">
                    <TextBlock x:Name="QuickActionsLabelText"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                      Next actions
                    </TextBlock>
                    <TextBlock x:Name="QuickActionsValueText"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                      -
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border Grid.Column="3"
                      Background="{ThemeResource ElevatedAcrylicBrush}"
                      BorderBrush="{ThemeResource GlowBorderBrush}"
                      BorderThickness="1" CornerRadius="8" Padding="0">
                <StackPanel>
                  <Border Height="2" CornerRadius="8,8,0,0"
                          Background="{ThemeResource AccentGradientHorizontalBrush}" />
                  <StackPanel Spacing="4" Padding="14">
                    <TextBlock x:Name="QuickEventsLabelText"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                      Blackbox events
                    </TextBlock>
                    <TextBlock x:Name="QuickEventsValueText"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                      -
                    </TextBlock>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>

            <!-- 2-column Master-Detail layout -->
            <Grid x:Name="TriageTwoColumnGrid" ColumnSpacing="16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
              </Grid.ColumnDefinitions>

              <!-- ── Main column ── -->
              <Border x:Name="MainColumnDivider" Grid.Column="0" BorderThickness="0,0,1,0"
                      BorderBrush="{ThemeResource GlowBorderBrush}" Padding="0">
              <StackPanel Spacing="12">

                <!-- Suspects (always visible, no Expander) -->
                <Border Background="{ThemeResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource GlowBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="3" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="8,0,0,8"
                            Background="{ThemeResource AccentGradientBrush}" />
                    <StackPanel Grid.Column="1" Spacing="10" Padding="20">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8D7;" FontSize="18"
                                  Foreground="{ThemeResource AccentBrush}" />
                        <TextBlock x:Name="SuspectsSectionTitleText"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                          Actionable Candidates
                        </TextBlock>
                      </StackPanel>
                      <ListView x:Name="SuspectsList" SelectionMode="None" MaxHeight="320"
                                Background="Transparent" BorderThickness="0"
                                AutomationProperties.Name="Suspect modules list">
                        <ListView.ItemTemplate>
                          <DataTemplate x:DataType="local:SuspectItem">
                            <Border Margin="0,0,0,6" Padding="12" CornerRadius="6"
                                    BorderBrush="{ThemeResource ItemBorderBrush}" BorderThickness="1"
                                    Background="{ThemeResource ItemBackgroundBrush}">
                              <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="Auto" />
                                  <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="999"
                                        Padding="10,4" VerticalAlignment="Top"
                                        Background="{ThemeResource AccentSoftBrush}">
                                  <TextBlock FontSize="11" FontWeight="SemiBold"
                                             Foreground="{ThemeResource AccentBrush}"
                                             Text="{x:Bind Confidence}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                  <TextBlock FontWeight="SemiBold"
                                             Text="{x:Bind Module}" TextWrapping="WrapWholeWords"
                                             Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                  <TextBlock FontSize="13" Text="{x:Bind Reason}"
                                             TextWrapping="WrapWholeWords"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ListView.ItemTemplate>
                      </ListView>
                    </StackPanel>
                  </Grid>
                </Border>

                <!-- Callstack (Expander, default expanded) -->
                <Border Background="{ThemeResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="8">
                  <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            IsExpanded="True">
                    <Expander.Header>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7B8;" FontSize="18"
                                  Foreground="{ThemeResource AccentBrush}" />
                        <TextBlock x:Name="CallstackLabelText" Text="Callstack"
                                   FontWeight="SemiBold" FontSize="17"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                      </StackPanel>
                    </Expander.Header>
                    <ListView x:Name="CallstackList" MaxHeight="500" SelectionMode="None"
                              Background="Transparent" BorderThickness="0"
                              AutomationProperties.Name="Callstack frames">
                      <ListView.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords"
                                     FontFamily="Cascadia Code" FontSize="12" Margin="0,0,0,4"
                                     Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </Expander>
                </Border>

                <!-- Evidence (Expander, default collapsed) -->
                <Border Background="{ThemeResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="8">
                  <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            IsExpanded="False">
                    <Expander.Header>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE773;" FontSize="18"
                                  Foreground="{ThemeResource AccentBrush}" />
                        <TextBlock x:Name="EvidenceLabelText" Text="Evidence"
                                   FontWeight="SemiBold" FontSize="17"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                      </StackPanel>
                    </Expander.Header>
                    <ListView x:Name="EvidenceList" MaxHeight="500" SelectionMode="None"
                              Background="Transparent" BorderThickness="0"
                              AutomationProperties.Name="Evidence items">
                      <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:EvidenceViewItem">
                          <Border Margin="0,0,0,6" Padding="12" CornerRadius="6"
                                  BorderBrush="{ThemeResource ItemBorderBrush}" BorderThickness="1"
                                  Background="{ThemeResource ItemBackgroundBrush}">
                            <Grid ColumnSpacing="12">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <Border Grid.Column="0" CornerRadius="999"
                                      Padding="10,4" VerticalAlignment="Top"
                                      Background="{ThemeResource AccentSoftBrush}">
                                <TextBlock FontSize="11" FontWeight="SemiBold"
                                           Foreground="{ThemeResource AccentBrush}"
                                           Text="{x:Bind Confidence}" />
                              </Border>
                              <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{x:Bind Title}" TextWrapping="WrapWholeWords"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                <TextBlock FontSize="13" Text="{x:Bind Details}"
                                           TextWrapping="WrapWholeWords"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </Expander>
                </Border>

                <!-- Resources (Expander, default collapsed) -->
                <Border Background="{ThemeResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="8">
                  <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            IsExpanded="False">
                    <Expander.Header>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;" FontSize="18"
                                  Foreground="{ThemeResource AccentBrush}" />
                        <TextBlock x:Name="ResourcesLabelText" Text="Recent Resources"
                                   FontWeight="SemiBold" FontSize="17"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                      </StackPanel>
                    </Expander.Header>
                    <ListView x:Name="ResourcesList" MaxHeight="500" SelectionMode="None"
                              Background="Transparent" BorderThickness="0"
                              AutomationProperties.Name="Recent resources list">
                      <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ResourceViewItem">
                          <Border Margin="0,0,0,6" Padding="12" CornerRadius="6"
                                  BorderBrush="{ThemeResource ItemBorderBrush}" BorderThickness="1"
                                  Background="{ThemeResource ItemBackgroundBrush}">
                            <StackPanel Spacing="2">
                              <TextBlock FontWeight="SemiBold"
                                         Text="{x:Bind Path}" TextWrapping="WrapWholeWords"
                                         Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                              <TextBlock FontSize="12" Text="{x:Bind Kind}"
                                         Foreground="{ThemeResource AccentBrush}" />
                              <TextBlock FontSize="12" Text="{x:Bind Providers}"
                                         TextWrapping="WrapWholeWords"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                              <TextBlock FontSize="12" Text="{x:Bind Conflict}"
                                         Foreground="{ThemeResource ConflictBrush}" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </Expander>
                </Border>

                <!-- Events (Expander, default collapsed) -->
                <Border Background="{ThemeResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="8">
                  <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            IsExpanded="False">
                    <Expander.Header>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE916;" FontSize="18"
                                  Foreground="{ThemeResource AccentBrush}" />
                        <TextBlock x:Name="EventsLabelText" Text="Events (Blackbox)"
                                   FontWeight="SemiBold" FontSize="17"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                      </StackPanel>
                    </Expander.Header>
                    <ListView x:Name="EventsList" MaxHeight="600" SelectionMode="None"
                              Background="Transparent" BorderThickness="0"
                              AutomationProperties.Name="Blackbox events list">
                      <ListView.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords"
                                     FontFamily="Cascadia Code" FontSize="12" Margin="0,0,0,4"
                                     Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </Expander>
                </Border>

              </StackPanel>
              </Border>

              <!-- ── Sidebar column ── -->
              <StackPanel x:Name="TriageSidebar" Grid.Column="1" Spacing="12">

                <!-- Reviewer feedback loop -->
                <Border Background="{ThemeResource ElevatedAcrylicBrush}"
                        BorderBrush="{ThemeResource GlowBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                  <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <FontIcon Glyph="&#xE70F;" FontSize="16"
                                Foreground="{ThemeResource PurpleAccentBrush}" />
                      <TextBlock x:Name="TriageEditorTitleText"
                                 Text="Review Feedback"
                                 FontSize="15" FontWeight="SemiBold"
                                 Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock x:Name="ReviewStatusLabelText"
                                 Text="Review status"
                                 FontSize="12"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                      <ComboBox x:Name="ReviewStatusComboBox"
                                SelectedIndex="0"
                                AutomationProperties.Name="Review status selector">
                        <ComboBoxItem x:Name="ReviewStatusUnreviewedItem"
                                      Tag="unreviewed"
                                      Content="Unreviewed" />
                        <ComboBoxItem x:Name="ReviewStatusReviewedItem"
                                      Tag="reviewed"
                                      Content="Reviewed" />
                        <ComboBoxItem x:Name="ReviewStatusConfirmedItem"
                                      Tag="confirmed"
                                      Content="Confirmed" />
                        <ComboBoxItem x:Name="ReviewStatusTriagedItem"
                                      Tag="triaged"
                                      Content="Triaged" />
                        <ComboBoxItem x:Name="ReviewStatusDoneItem"
                                      Tag="done"
                                      Content="Done" />
                      </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock x:Name="VerdictLabelText"
                                 Text="Verdict"
                                 FontSize="12"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                      <TextBox x:Name="VerdictBox"
                               PlaceholderText="Top conclusion or short verdict"
                               AutomationProperties.Name="Triage verdict" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock x:Name="ActualCauseLabelText"
                                 Text="Actual cause"
                                 FontSize="12"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                      <TextBox x:Name="ActualCauseBox"
                               PlaceholderText="What actually caused the CTD"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               MinHeight="72"
                               AutomationProperties.Name="Actual CTD cause" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock x:Name="GroundTruthModLabelText"
                                 Text="Ground truth mod"
                                 FontSize="12"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                      <TextBox x:Name="GroundTruthModBox"
                               PlaceholderText="Confirmed mod/plugin if known"
                               AutomationProperties.Name="Ground truth mod name" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock x:Name="ReviewNotesLabelText"
                                 Text="Review notes"
                                 FontSize="12"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                      <TextBox x:Name="ReviewNotesBox"
                               PlaceholderText="Why the top candidate was right or wrong"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               MinHeight="96"
                               AutomationProperties.Name="Review notes" />
                    </StackPanel>

                    <TextBlock x:Name="TriageMetaText"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <Button x:Name="SaveTriageButton"
                            Click="SaveTriageButton_Click"
                            Content="Save review"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            AutomationProperties.Name="Save triage review"
                            ToolTipService.ToolTip="Save review fields to the summary JSON (Ctrl+S)">
                      <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="S" />
                      </Button.KeyboardAccelerators>
                    </Button>
                  </StackPanel>
                </Border>

                <!-- Crash info card (always visible) -->
                <Border Background="{ThemeResource ElevatedAcrylicBrush}"
                        BorderBrush="{ThemeResource GlowBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16">
                  <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                      <FontIcon Glyph="&#xE946;" FontSize="16"
                                Foreground="{ThemeResource PurpleAccentBrush}" />
                      <TextBlock Text="Crash Info" FontSize="15" FontWeight="SemiBold"
                                 Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="BucketText" FontSize="13"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock x:Name="ModuleText" FontSize="13"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock x:Name="ModNameText" FontSize="13"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                  </StackPanel>
                </Border>

                <!-- Recommendations (Expander, default expanded) -->
                <Border Background="{ThemeResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="8">
                  <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            IsExpanded="True">
                    <Expander.Header>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8FB;" FontSize="18"
                                  Foreground="{ThemeResource PurpleAccentBrush}" />
                        <TextBlock x:Name="NextStepsSectionTitleText"
                                   Text="Recommended Next Steps"
                                   FontWeight="SemiBold" FontSize="17"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                      </StackPanel>
                    </Expander.Header>
                    <ListView x:Name="RecommendationsList" SelectionMode="None" MaxHeight="320"
                              Background="Transparent" BorderThickness="0"
                              AutomationProperties.Name="Recommended actions list">
                      <ListView.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,6" Padding="12" CornerRadius="6"
                                  BorderBrush="{ThemeResource ItemBorderBrush}" BorderThickness="1"
                                  Background="{ThemeResource ItemBackgroundBrush}">
                            <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                          </Border>
                        </DataTemplate>
                      </ListView.ItemTemplate>
                    </ListView>
                  </Expander>
                </Border>

                <!-- Troubleshooting (Expander, default collapsed) -->
                <Border x:Name="TroubleshootingCard"
                        Background="{ThemeResource CardAcrylicBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="8"
                        Visibility="Collapsed">
                  <Expander x:Name="TroubleshootingExpander"
                            IsExpanded="False"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE90F;" FontSize="18"
                                  Foreground="{ThemeResource PurpleAccentBrush}" />
                        <TextBlock Text="Troubleshooting"
                                   FontWeight="SemiBold" FontSize="17"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                      </StackPanel>
                    </Expander.Header>
                    <ItemsControl x:Name="TroubleshootingList" Margin="8,4">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Expander>
                </Border>

              </StackPanel>
            </Grid>

          </StackPanel>

          <!-- ════════════════════════════════════════════
               RAW DATA PANEL
               ════════════════════════════════════════════ -->
          <StackPanel x:Name="RawDataPanel" Spacing="16" Visibility="Collapsed" HorizontalAlignment="Stretch">

            <TextBlock FontSize="30" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}">
              Reports &amp; Raw Data
            </TextBlock>

            <!-- WCT JSON -->
            <Border Background="{ThemeResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
              <StackPanel Spacing="10">
                <TextBlock x:Name="WctLabelText" Text="WCT JSON"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBox x:Name="WctTextBox"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                         FontFamily="Cascadia Code" FontSize="12"
                         MinHeight="200" MaxHeight="400"
                         AutomationProperties.Name="WCT JSON content" />
              </StackPanel>
            </Border>

            <!-- Full report -->
            <Border Background="{ThemeResource CardAcrylicBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
              <StackPanel Spacing="10">
                <TextBlock x:Name="ReportLabelText" Text="Report"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBox x:Name="ReportTextBox"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="13"
                         MinHeight="200" MaxHeight="500"
                         AutomationProperties.Name="Analysis report text" />
              </StackPanel>
            </Border>
          </StackPanel>

        </Grid>
      </ScrollViewer>
    </NavigationView>
  </Grid>
</Window>
